<Layout title="Lukas Downes">
  <header id="home">
    <h1>Home</h1>
    <div class="grid">
      <img src="/assets/face.svg" alt="Line Picture of Lukas's Face" />
      <div>
        <p>
          Hello... <br />
          My name is <br />
          <span class="red">&lt;Lukas Downes&gt;</span> <br />
          This is my portfolio.
        </p>
      </div>
      <h2>Content...</h2>
      <nav aria-label="home-menu">
        <ul>
          <li class="active">Home</li>
          <li><a href="#contact">Contact</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="#design">Design Choices</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </nav>
    </div>
    <a href="#scroll-down-arrow">
